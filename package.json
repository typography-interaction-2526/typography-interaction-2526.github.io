		"serve": "npm run clean && npx @11ty/eleventy --serve --port=80 --quiet"
	},
	"dependencies": {
		"@11ty/eleventy": ">=4.0.0-alpha.0 <5.0.0",
		"@11ty/eleventy-plugin-webc": "github:11ty/eleventy-plugin-webc",
		"@11ty/webc": "github:11ty/webc"
	}
}
