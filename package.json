{
	"name": "typography-interaction-2526",
	"title": "Typography & Interaction, 2025–2026",
	"description": "Course site for Typography & Interaction, 2025–2026.",
	"homepage": "https://typography-interaction-2526.github.io",
	"type": "module",
	"contributors": [
		{
			"name": "Michael Fehrenbach",
			"url": "https://michaelfehrenbach.com",
			"email": "mfehrenbach@newschool.edu"
		}
	],
	"scripts": {
		"clean": "node -e \"import('fs').then(fs => fs.rmSync('_site', { recursive: true, force: true }))\"",
		"build": "npm run clean && npx @11ty/eleventy",
		"serve": "npm run clean && npx @11ty/eleventy --serve --port=80 --quiet"
	},
	"dependencies": {
		"@11ty/eleventy": ">=4.0.0-alpha.0 <5.0.0",
		"@11ty/eleventy-plugin-webc": "github:11ty/eleventy-plugin-webc",
		"@11ty/webc": "github:11ty/webc",
		"@mdit-vue/plugin-component": "^2.1.4",
		"markdown-it": "^14.1.0",
		"markdown-it-abbr": "^2.0.0",
		"markdown-it-anchor": "^9.2.0",
		"markdown-it-attrs": "^4.3.1",
		"markdown-it-deflist": "^3.0.0",
		"markdown-it-header-sections": "^1.0.0",
		"striptags": "^3.2.0"
	}
}
