{
	"name": "typography-interaction-2526",
	"title": "Typography & Interaction, 2025–2026",
	"description": "Course site for Typography & Interaction, 2025–2026.",
	"homepage": "https://typography-interaction-2526.github.io",
	"type": "module",
	"contributors": [
		{
			"name": "Michael Fehrenbach",
			"url": "https://michaelfehrenbach.com",
			"email": "mfehrenbach@newschool.edu"
		}
	],
	"scripts": {
		"clean": "node -e \"import('fs').then(fs=>fs.rmSync('_site',{recursive:true,force:true}))\"",
