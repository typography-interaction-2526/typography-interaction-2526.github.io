{
	"excludes": [
		"_site",
		"content/topic/*/**",
		"node_modules"
	],
	"markup": {
		"associations": [
			"*.html",
			"*.webc"
		],
		"closingTagLineBreakForEmpty": "never",
		"component.selfClosing": false,
		"doctypeKeywordCase": "lower",
		"html.normal.selfClosing": false,
		"html.void.selfClosing": false,
		"maxAttrsPerLine": 1,
		"printWidth": 256,
		"scriptIndent": true,
		"singleAttrSameLine": true,
		"styleIndent": true,
		"svg.selfClosing": false
	},
	"plugins": [
		"https://plugins.dprint.dev/g-plane/markup_fmt-v0.23.1.wasm",
		"https://plugins.dprint.dev/json-0.20.0.wasm",
		"https://plugins.dprint.dev/markdown-0.19.0.wasm"
	],
	"useTabs": true
}
