<script webc:setup>
	export const test = 'Working?!'
</script>
<ol>
	<li webc:for="item of [...$data.collections.root, ...$data.collections.pages]">
		<a
			webc:if="item.url != $data.page.url"
			:href="item.url"
		>
			<p @html="markdownInline(item.data.title)"></p>
		</a>
		<slot webc:elseif="item.url === $data.page.url"></slot>
	</li>
</ol>
