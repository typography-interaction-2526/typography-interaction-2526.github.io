<script webc:setup>
	const typeOrder = ['Project', 'Agenda', 'Topic']

	export const groupedPages = (() => {
		const typeOrder = ['Project', 'Agenda', 'Topic']

		const pages = [...$data.collections.pages]
			.filter(page => page.data.week)
			.sort((a, b) => (a.data.week - b.data.week) || (typeOrder.indexOf(a.data.type) - typeOrder.indexOf(b.data.type)))

		const map = new Map()

		for (const page of pages) {
			const unit = page.data.unitNumber
			if (!map.has(unit)) map.set(unit, [])
			map.get(unit).push(page)
		}
		return Array.from(map.values())
	})()
</script>

<ul>
	<li webc:for="item of [...$data.collections.root]">
		<block webc:import="page-link.webc"></block>
		<slot webc:if="item.url === $data.page.url"></slot>
	</li>
	<li webc:for="unit of groupedPages">
		<p><em><strong @text="unit[0].data.unit"></strong></em></p>
		<ul>
			<li webc:for="item of unit">
				<block webc:import="page-link.webc"></block>
				<slot webc:if="item.url === $data.page.url"></slot>
			</li>
		</ul>
	</li>
</ul>
