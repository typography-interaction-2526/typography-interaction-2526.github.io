<link href="../../styles/variables.css" rel="stylesheet" webc:bucket="base">
<style
	webc:keep
	@raw="`
	@layer reset, base, components, print;

	@import url('/styles/reset.css') layer(reset);
	@import url('${getBundleFileUrl('css', 'base')}')  layer(base);
	`"
></style>
<style webc:keep @raw="`@layer components { ${getBundle('css')} }`"></style>
