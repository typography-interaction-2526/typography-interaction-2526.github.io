<!doctype html>
<html lang="en">
	<script webc:setup>
		export const getDescription = ({ content, description }) => {
			const document = parse(content)
			const descriptions = document.querySelectorAll('main [data-description]')

			return stripTags(
				description
					? description
					: descriptions.length
						? descriptions.map((node) => node.innerHTML).join(' ')
						: document.querySelector('main p')?.innerHTML || '',
			)
				.trim()
				.replace(/\s+/g, ' ') // Collapse white space.
				.replace(/:$/, '.') // Fix ending colons.
				.replace(/&nbsp;/g, '\u00A0') // Decode entity so Eleventy doesn’t `&amp;` it.

		}
	</script>
	<head>
		<meta charset="utf-8">
		<meta
			content="initial-scale=1, width=device-width, viewport-fit=cover"
			name="viewport"
		>
		<title @html="stripTags(title || course.title)"></title>
		<template
			webc:if="!eleventyExcludeFromCollections"
			webc:nokeep
		>
			<!-- TODO Generate /preview metadata? -->
			<meta
				:content="getDescription($data)"
				name="description"
			>
			<meta
				webc:if="meta"
				:content="`${$data.pkg.homepage}/assets/meta/${$data.page.fileSlug ? $data.page.fileSlug : 'index'}.png`"
				property="og:image"
			>
		</template>
		<meta
			webc:else
			content="noindex, nofollow"
			name="robots"
		>
		<link
			href="/assets/icons/favicon.ico"
			rel="icon"
			sizes="64x64"
			type="image/x-icon"
		>
		<link
			:href="`/assets/icons/favicon${unitNumber ? '--' + unitNumber : ''}.svg`"
			rel="icon"
			type="image/svg+xml"
		>
		<link
			:href="`/assets/icons/touch${unitNumber ? '--' + unitNumber : ''}.png`"
			rel="apple-touch-icon"
		>
		<template
			webc:import="blocks/styles.webc"
			webc:nokeep
		></template>
		<script
			webc:keep
			src="/assets/ti-preview/index.js"
			type="module"
		></script>
		<script
			webc:keep
			@raw="getBundle(`js`)"
			type="module"
		></script>
	</head>
	<body>
		<block webc:import="blocks/warning.webc"></block>
		<template
			webc:nokeep
			@raw="content"
		></template>
	</body>
</html>
