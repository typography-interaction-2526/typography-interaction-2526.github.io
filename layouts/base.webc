<!doctype html>
<html lang="en">
	<script webc:setup>
		export const addNbsp = (string) => string.replace(' ', '\u00A0') // Prevent Safari from hiding words.
	</script>
	<head>
		<meta charset="utf-8">
		<meta
			content="initial-scale=1, width=device-width, viewport-fit=cover"
			name="viewport"
		>
		<title @text="stripTags(addNbsp(markdown(title)))"></title>
		<link
			href="/assets/icons/favicon.ico"
			rel="icon"
			sizes="64x64"
			type="image/x-icon"
		>
		<link
			:href="`/assets/icons/favicon${unitNumber ? '--' + unitNumber : ''}.svg`"
			rel="icon"
			type="image/svg+xml"
		>
		<link
			:href="`/assets/icons/touch${unitNumber ? '--' + unitNumber : ''}.png`"
			rel="apple-touch-icon"
		>
		<meta
			:content="`${$data.pkg.homepage}/assets/icons/meta.png`"
			property="og:image"
		>
		<template
			webc:import="blocks/styles.webc"
			webc:nokeep
		></template>
		<script
			webc:keep
			src="/assets/ti-preview/index.js"
			type="module"
		></script>
		<script
			webc:keep
			@raw="getBundle(`js`)"
			type="module"
		></script>
	</head>
	<body>
		<block webc:import="blocks/warning.webc"></block>
		<template
			webc:nokeep
			@raw="content"
		></template>
	</body>
</html>
