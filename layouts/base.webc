<script front>
	const pageClass = url => (url != '/') ? String(url).split('/').filter(part => part.length > 1)[0] : ''
</script>

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8">
		<meta content="initial-scale=1, width=device-width, viewport-fit=cover" name="viewport">
		<title @text="title"></title>
	</head>
	<body :class="pageClass(page.url)" @html="content"></body>
</html>
